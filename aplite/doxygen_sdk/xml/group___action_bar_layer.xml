<codeline><highlight class="normal"><sp/><sp/><ref refid="group___window_1gae09d8d7299a9d5a750a898a70f64bdec" kindref="member">window_single_click_subscribe</ref>(<ref refid="group___clicks_1ggaa60e15d86cfe7033f28c7d066c85266ea65a919b8a0f4539acfb865eb2a2dd9d0" kindref="member">BUTTON_ID_DOWN</ref>,<sp/>(<ref refid="group___clicks_1ga9a923c600f6774d9858ae96b57d308a6" kindref="member">ClickHandler</ref>)<sp/>my_next_click_handler);</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><ref refid="group___window_1gae09d8d7299a9d5a750a898a70f64bdec" kindref="member">window_single_click_subscribe</ref>(<ref refid="group___clicks_1ggaa60e15d86cfe7033f28c7d066c85266eafb03cb7921a8bb7893cd8093a1a5e9cb" kindref="member">BUTTON_ID_UP</ref>,<sp/>(<ref refid="group___clicks_1ga9a923c600f6774d9858ae96b57d308a6" kindref="member">ClickHandler</ref>)<sp/>my_previous_click_handler);</highlight></codeline>
