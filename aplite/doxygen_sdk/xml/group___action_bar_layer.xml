</parameternamelist>
<parameterdescription>
<para>The identifier of the button for which to clear the icon </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="see"><para><ref refid="group___action_bar_layer_1ga03f3cf8b2817e31ff6c9b670f934dfe6" kindref="member">action_bar_layer_set_icon()</ref> </para>
</simplesect>
</para>
        </detaileddescription>
