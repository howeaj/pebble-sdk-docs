        <definition>void action_bar_layer_set_click_config_provider</definition>
        <argsstring>(ActionBarLayer *action_bar, ClickConfigProvider click_config_provider)</argsstring>
        <name>action_bar_layer_set_click_config_provider</name>
        <param>
          <type>ActionBarLayer *</type>
