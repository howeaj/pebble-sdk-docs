      <memberdef kind="function" id="group___app_message_1ga26735aa7eb22ab58bd7496e673d03155" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type><ref refid="group___app_message_1ga695a78c926b20edbb14d7faf5a78c29e" kindref="member">AppMessageResult</ref></type>
        <definition>AppMessageResult app_message_open</definition>
        <argsstring>(const uint32_t size_inbound, const uint32_t size_outbound)</argsstring>
        <name>app_message_open</name>
        <param>
          <type>const <ref refid="group___standard_c_1ga9c50f76d143708c221a73ff579a463a4" kindref="member">uint32_t</ref></type>
          <declname>size_inbound</declname>
        </param>
        <param>
          <type>const <ref refid="group___standard_c_1ga9c50f76d143708c221a73ff579a463a4" kindref="member">uint32_t</ref></type>
          <declname>size_outbound</declname>
        </param>
        <briefdescription>
<para>Open AppMessage to transfers. </para>
        </briefdescription>
        <detaileddescription>
<para>Use <ref refid="group___dictionary_1gad31424a83643adbfd9e84c4bd37e4627" kindref="member">dict_calc_buffer_size_from_tuplets()</ref> or <ref refid="group___dictionary_1ga0551d069624fb5bfc066fecfa4153bde" kindref="member">dict_calc_buffer_size()</ref> to estimate the size you need.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">size_inbound</parametername>
</parameternamelist>
<parameterdescription>
<para>The required size for the Inbox buffer </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">size_outbound</parametername>
</parameternamelist>
<parameterdescription>
<para>The required size for the Outbox buffer</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>A result code such as <ref refid="group___app_message_1gga695a78c926b20edbb14d7faf5a78c29ea12a6ea49b151222e76cf4b99b7c0c4cc" kindref="member">APP_MSG_OK</ref> or <ref refid="group___app_message_1gga695a78c926b20edbb14d7faf5a78c29ead1cce21da2d8b46e305f9550a7384238" kindref="member">APP_MSG_OUT_OF_MEMORY</ref>.</para>
</simplesect>
<simplesect kind="note"><para>It is recommended that if the Inbox will be used, that at least the Inbox callbacks should be registered before this call. Otherwise it is possible for an Inbox message to be NACK&apos;ed without being seen by the application. </para>
</simplesect>
</para>
        </detaileddescription>
