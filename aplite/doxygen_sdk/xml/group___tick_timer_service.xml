        <type>void</type>
        <definition>void tick_timer_service_subscribe</definition>
        <argsstring>(TimeUnits tick_units, TickHandler handler)</argsstring>
        <name>tick_timer_service_subscribe</name>
        <param>
          <type><ref refid="group___tick_timer_service_1ga0423d00e0eb199de523a92031b5a1107" kindref="member">TimeUnits</ref></type>
          <declname>tick_units</declname>
