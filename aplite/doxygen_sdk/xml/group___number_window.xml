        <type>NumberWindow *</type>
        <definition>NumberWindow * number_window_create</definition>
        <argsstring>(const char *label, NumberWindowCallbacks callbacks, void *callback_context)</argsstring>
        <name>number_window_create</name>
        <param>
          <type>const char *</type>
          <declname>label</declname>
        </param>
