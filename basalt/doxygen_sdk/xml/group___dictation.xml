      <memberdef kind="function" id="group___dictation_1ga9cdf88f9e484b512b2f07ff94849732b" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void dictation_session_enable_confirmation</definition>
        <argsstring>(DictationSession *session, bool is_enabled)</argsstring>
        <name>dictation_session_enable_confirmation</name>
        <param>
          <type>DictationSession *</type>
          <declname>session</declname>
        </param>
        <param>
          <type>bool</type>
          <declname>is_enabled</declname>
        </param>
        <briefdescription>
<para>Enable or disable user confirmation of transcribed text, which allows the user to accept or reject (and restart) the transcription. Must be called before the session is started. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>session</parametername>
</parameternamelist>
<parameterdescription>
<para>dictation session to modify </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>is_enabled</parametername>
</parameternamelist>
<parameterdescription>
<para>set to true to enable user confirmation of transcriptions (default), false to disable </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
