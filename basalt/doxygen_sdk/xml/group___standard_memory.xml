          <declname>n</declname>
        </param>
        <briefdescription>
<para>Compares the first n bytes of memory regions ptr1 and ptr2. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>ptr1</parametername>
</parameternamelist>
