        </param>
        <param>
          <type>uint8_t</type>
          <declname>min_clicks</declname>
        </param>
        <param>
          <type>uint8_t</type>
          <declname>max_clicks</declname>
        </param>
        <param>
          <type><ref refid="group___standard_c_1gaa686eebdb9c21527b4ed32a4427c28b7" kindref="member">uint16_t</ref></type>
