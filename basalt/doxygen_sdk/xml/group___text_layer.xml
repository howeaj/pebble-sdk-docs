      <memberdef kind="function" id="group___text_layer_1ga473f54e257f089a9e7a5df0a0e56f625" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void text_layer_enable_screen_text_flow_and_paging</definition>
        <argsstring>(TextLayer *text_layer, uint8_t inset)</argsstring>
        <name>text_layer_enable_screen_text_flow_and_paging</name>
        <param>
          <type>TextLayer *</type>
          <declname>text_layer</declname>
        </param>
        <param>
          <type>uint8_t</type>
          <declname>inset</declname>
        </param>
        <briefdescription>
<para>Enables text flow following the boundaries of the screen and pagination that introduces extra line spacing at page breaks to avoid partially clipped lines for the TextLayer. If the TextLayer is part of a <ref refid="group___scroll_layer" kindref="compound">ScrollLayer</ref> the ScrollLayer&apos;s frame will be used to configure paging. </para>
        </briefdescription>
        <detaileddescription>
<para><simplesect kind="note"><para>Make sure the TextLayer is part of the view hierarchy before calling this function. Otherwise it has no effect. </para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>text_layer</parametername>
</parameternamelist>
<parameterdescription>
<para>The TextLayer for which to enable text flow and paging </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>inset</parametername>
</parameternamelist>
<parameterdescription>
<para>Additional amount of pixels to inset to the inside of the screen for text flow </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="see"><para><ref refid="group___text_layer_1ga5aa332145a2bf45e742957ac07e27b99" kindref="member">text_layer_restore_default_text_flow_and_paging</ref> </para>
</simplesect>
<simplesect kind="see"><para><ref refid="group___text_drawing_1ga84e08b94b1509fd06f00735c1f67f2c3" kindref="member">graphics_text_attributes_enable_screen_text_flow</ref> </para>
</simplesect>
<simplesect kind="see"><para><ref refid="group___text_drawing_1gaf447fb3ce85161d8d1ccb97ef78fed13" kindref="member">graphics_text_attributes_enable_paging</ref> </para>
</simplesect>
</para>
        </detaileddescription>
