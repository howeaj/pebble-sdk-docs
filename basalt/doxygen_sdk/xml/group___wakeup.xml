</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>cookie</parametername>
</parameternamelist>
<parameterdescription>
<para>App provided reason for the wakeup event </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>True if app was launched due to a wakeup event, false otherwise </para>
</simplesect>
</para>
